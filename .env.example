# Pegasus FE environment template. Copy to .env.local for local dev
# (overrides apply per-environment in production via the host platform).

# Base URL of the Go API (sypher-api). Defaults match a local dev
# stack on :8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# GA4 measurement id. Same env var name as sypher-shell so one value
# covers both apps reporting to the same GA property. Set this to
# enable client-side analytics (page views + user actions); leave
# empty to suppress all gtag injection — track() becomes a no-op.
NEXT_PUBLIC_GA_ID=
